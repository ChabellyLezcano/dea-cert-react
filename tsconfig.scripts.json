{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts"],
  "exclude": ["src/**/*.tsx", "node_modules"]
}
