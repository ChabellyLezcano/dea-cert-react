# Supabase project settings (Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run `npm run db:seed`. This is the "service_role"
# key (Project Settings > API) — it bypasses Row Level Security, so it must
# NEVER be prefixed with VITE_ (which would ship it to the browser) and
# never committed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
